<?xml version="1.0" encoding="utf-8"?>
<project>
	<!-- _________________________ Application Settings _________________________ -->

	<app title="FNF: Vs Sonic.exe" file="Kade Engine" package="com.brenninho.sonicexe.android" main="Main" version="0.2.7.1" company="brenninho" />

	<!--Switch Export with Unique ApplicationID and Icon-->
	<set name="APP_ID" value="0x0100f6c013bbc000" />

	<!--The flixel preloader is not accurate in Chrome. You can use it regularly if you embed the swf into a html file
		or you can set the actual size of your file manually at "FlxPreloaderBase-onUpdate-bytesTotal"-->
	<!-- <app preloader="Preloader" resizable="true" /> -->
	<app preloader="flixel.system.FlxPreloader" />

	<!--Minimum without FLX_NO_GAMEPAD: 11.8, without FLX_NO_NATIVE_CURSOR: 11.2-->
	<set name="SWF_VERSION" value="11.8" />

	<!-- ____________________________ Window Settings ___________________________ -->

	<!--These window settings apply to all targets-->
	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />

	<!--HTML5-specific-->
	<window if="html5" resizable="true" />

	<!--Desktop-specific-->
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false"/>

	<!--Mobile-specific-->
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" resizable="false"/>

	<!--Android-specific - Configurações adicionais para Android-->
	<window if="android" orientation="landscape" fullscreen="true" width="0" height="0" resizable="false"/>

	<!--Switch-specific-->
	<window if="switch" orientation="landscape" fullscreen="true" width="0" height="0" resizable="true" />

	<!-- _____________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="export/debug" if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit" if="32bit" />

	<classpath name="source" />

	<assets path="assets/preload" rename="assets" exclude="*.ogg" if="web"/>
	<assets path="assets/preload" rename="assets" exclude="*.mp3" unless="web"/>
	
	<!-- <define name="PRELOAD_ALL" /> -->
	<define name="PRELOAD_ALL" unless="web" />
	<define name="NO_PRELOAD_ALL" unless="PRELOAD_ALL"/>
	
	<section if="PRELOAD_ALL">
		<library name="songs"    preload="true" />
		<library name="shared"   preload="true" />
		<library name="videos"   preload="true" />
		<library name="exe"      preload="true" />
	</section>
	
	<section if="NO_PRELOAD_ALL">
		<library name="songs"    preload="false" />
		<library name="shared"   preload="false" />
		<library name="videos"   preload="false" />
		<library name="exe"   	 preload="false" />
	</section>
	
	<assets path="assets/songs"    library="songs"    exclude="*.ogg" if="web"/>
	<assets path="assets/songs"    library="songs"    exclude="*.mp3" unless="web"/>
	<assets path="assets/shared"   library="shared"   exclude="*.ogg" if="web"/>
	<assets path="assets/shared"   library="shared"   exclude="*.mp3" unless="web"/>
	<assets path="assets/exe"      library="exe"	   exclude="*.ogg" if="web"/>
	<assets path="assets/exe"      library="exe"   	   exclude="*.mp3" unless="web"/>
	<assets path="assets/videos" exclude="*.mp3" if="web"/>
	<assets path="assets/videos" exclude="*.ogg" unless="web"/>

	<!-- Configuração especial para Android: assets embeddados para evitar extração -->
	<assets path="assets/" if="android" embed="true" rename="assets" />
	
	<!-- Plugins e DLLs só para Windows -->
	<assets path="plugins/" rename='' if="windows"/>
	<assets path="dlls/" rename='' if="windows"/>
	
	<!-- Mods - IMPORTANTE: Para Android, mods precisam ser embeddados ou salvos em storage -->
	<assets path='example_mods' rename='mods' embed='true' if="android"/>
	<assets path='example_mods' rename='mods' embed='false' unless="android"/>
	
	<assets path='art/readme.txt' rename='do NOT readme.txt' />
	<assets path='LICENSE' rename='LICENSE.txt' />
	
	<!-- Fonts embeddadas para todos os alvos -->
	<assets path="assets/fonts" embed='true'/>

	<!-- _______________________________ Libraries ______________________________ -->

	<haxelib name="flixel" />


	<!--In case you want to use the addons package-->
	<haxelib name="flixel-addons" />
	<haxelib name="hscript" />
	
	<haxelib name="actuate" />
	
	<!-- WebM extension - condicional para desktop e Android -->
	<!-- WebM: somente desktop. Android usa WebM via cpp -->
	<haxelib name="extension-webm" if="desktop" />

	<!--In case you want to use the ui package-->
	<haxelib name="flixel-ui" />
	<haxelib name="newgrounds"/>
	<haxelib name="faxe" if='switch'/>
	<haxelib name="polymod"/>
	
	<!-- Bibliotecas específicas para desktop -->
	<haxelib name="discord_rpc" if="windows"/>
	<haxelib name="linc_luajit" if="windows"/>

	<!-- ______________________________ Haxedefines _____________________________ -->

	<!--Desativa features não suportadas/no mobile para evitar crashes-->
	<haxedef name="FLX_NO_MOUSE" if="mobile" />
	<haxedef name="FLX_NO_KEYBOARD" if="mobile" />
	<haxedef name="FLX_NO_TOUCH" if="desktop" />
	
	<!-- Otimizações para mobile -->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="mobile" if="android" />
	
	<!--Desativa o debugger no release-->
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<!--Enable this for Nape release builds for a serious peformance improvement-->
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

	<!-- ___________________________ Android Settings ___________________________ -->
	
	<android>
		<!-- Permissões mínimas necessárias -->
		<uses-permission android:name="android.permission.INTERNET" />
		<uses-permission android:name="android.permission.VIBRATE" />
		<uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
		<uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
		
		<!-- Configurações de tela -->
		<activity android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|uiMode"/>
		<activity android:screenOrientation="sensorLandscape"/>
		
		<!-- Suporte a touch -->
		<touch android:enableZoomControls="false" android:multitouch="true"/>
		
		<!-- Tamanhos de ícone para Android -->
		<icon path="art/icon36.png" size="36" />
		<icon path="art/icon48.png" size="48" />
		<icon path="art/icon72.png" size="72" />
		<icon path="art/icon96.png" size="96" />
		<icon path="art/icon144.png" size="144" />
		<icon path="art/icon192.png" size="192" />
		
		<!-- Versão mínima do Android -->
		<uses-sdk android:minSdkVersion="16" android:targetSdkVersion="29" />
	</android>

	<!-- _________________________________ Ícones _______________________________ -->

	<!--Ícones para todas as plataformas-->
	<icon path="art/icon8.png" size='8'/>
	<icon path="art/icon16.png" size='16'/>
	<icon path="art/icon32.png" size='32'/>
	<icon path="art/icon64.png" size='64'/>
	<icon path="art/icon128.png" size='128'/>
	<icon path="art/icon256.png" size='256'/>
	<icon path="art/icon512.png" size='512'/>
	<icon path="art/iconOG.png" />

	<!-- _________________________________ Custom _______________________________ -->

	<!-- Definições para Newgrounds -->
	<haxedef name="NG_LOGIN" if="newgrounds" />
	
	<!-- Configuração de garbage collector para mobile -->
	<haxedef name="HXCPP_GC_GENERATIONAL" if="android" />
	<haxedef name="HXCPP_GC_MARK_SWEEP" if="android" />
	
	<!-- Compilação otimizada para Android -->
	<haxedef name="HXCPP_ARM64" if="android" />
	<haxedef name="HXCPP_ARMV7" if="android" />
	<haxedef name="HXCPP_X86" if="android" />
	
	<!-- Configuração de memória para evitar crashes -->
	<set name="HXCPP_M64" value="1" if="android" />
	
</project>